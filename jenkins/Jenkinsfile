pipeline {
    agent any

    environment {
        // Application Metadata
        APP_NAME = 'devops-app'
        DOCKER_HUB_USER = 'vivso000'
        DOCKER_IMAGE = "${DOCKER_HUB_USER}/${APP_NAME}"
        
        // Target AWS EC2 Deployment Instance
        EC2_PUBLIC_IP = '52.62.83.20'
        EC2_USER = 'ubuntu'

        // Jenkins Credentials Store IDs
        DOCKER_HUB_CREDS_ID = 'docker-hub-credentials'
        EC2_SSH_KEY_ID      = 'ec2-ssh-private-key'
    }

    options {
        buildDiscarder(logRotator(numToKeepStr: '10'))
        disableConcurrentBuilds()
        timeout(time: 15, unit: 'MINUTES')
        timestamps()
    }

    stages {
        stage('1. Checkout Source Code') {
            steps {
                echo "📥 Checking out latest commit [${env.GIT_COMMIT ?: 'LOCAL'}] from branch [${env.BRANCH_NAME ?: 'main'}]..."
                checkout scm
            }
        }

        stage('2. Maven Compile & Unit Tests') {
            steps {
                dir('application') {
                    echo "🧪 Executing Maven compilation and JUnit integration tests..."
                    script {
                        if (isUnix()) {
                            sh 'mvn clean test -B'
                        } else {
                            bat 'mvn clean test -B'
                        }
                    }
                }
            }
        }

        stage('3. Maven Package Fat-JAR') {
            steps {
                dir('application') {
                    echo "📦 Packaging Java Spring Boot application into runnable JAR..."
                    script {
                        if (isUnix()) {
                            sh 'mvn package -DskipTests -B'
                        } else {
                            bat 'mvn package -DskipTests -B'
                        }
                    }
                }
            }
        }

        stage('4. Build Docker Container Image') {
            steps {
                echo "🐳 Building Docker image: ${DOCKER_IMAGE}:latest and ${DOCKER_IMAGE}:${BUILD_NUMBER}..."
                script {
                    def buildCmd = "docker build -f docker/Dockerfile -t ${DOCKER_IMAGE}:latest -t ${DOCKER_IMAGE}:${BUILD_NUMBER} ."
                    if (isUnix()) {
                        sh buildCmd
                    } else {
                        bat buildCmd
                    }
                }
            }
        }

        stage('5. Push Image to Docker Hub Registry') {
            steps {
                echo "🔐 Authenticating with Docker Hub..."
                withCredentials([usernamePassword(credentialsId: "${DOCKER_HUB_CREDS_ID}", passwordVariable: 'DOCKER_PASSWORD', usernameVariable: 'DOCKER_USERNAME')]) {
                    script {
                        if (isUnix()) {
                            sh """
                                echo "\$DOCKER_PASSWORD" | docker login -u "\$DOCKER_USERNAME" --password-stdin
                                docker push ${DOCKER_IMAGE}:latest
                                docker push ${DOCKER_IMAGE}:${BUILD_NUMBER}
                                docker logout
                            """
                        } else {
                            bat """
                                echo %DOCKER_PASSWORD% | docker login -u %DOCKER_USERNAME% --password-stdin
                                docker push ${DOCKER_IMAGE}:latest
                                docker push ${DOCKER_IMAGE}:${BUILD_NUMBER}
                                docker logout
                            """
                        }
                    }
                }
            }
        }

        stage('6. Deploy to AWS EC2 via Remote SSH') {
            steps {
                echo "🚀 Establishing SSH session to EC2 instance (${EC2_PUBLIC_IP}) and running deployment..."
                withCredentials([sshUserPrivateKey(credentialsId: "${EC2_SSH_KEY_ID}", keyFileVariable: 'SSH_KEY', usernameVariable: 'SSH_USER')]) {
                    script {
                        if (isUnix()) {
                            sh """
                                scp -o StrictHostKeyChecking=no -i \$SSH_KEY scripts/deploy.sh \$SSH_USER@${EC2_PUBLIC_IP}:/home/\$SSH_USER/deploy.sh
                                ssh -o StrictHostKeyChecking=no -i \$SSH_KEY \$SSH_USER@${EC2_PUBLIC_IP} "chmod +x /home/\$SSH_USER/deploy.sh && /home/\$SSH_USER/deploy.sh ${DOCKER_IMAGE}:latest ${APP_NAME} 8080 8080"
                            """
                        } else {
                            bat """
                                @echo off
                                echo [INFO] Fixing Windows SSH Key Permissions for temporary key: "%SSH_KEY%"
                                icacls "%SSH_KEY%" /inheritance:r /grant:r *S-1-5-18:R /grant:r "%USERNAME%:R"
                                
                                echo [INFO] Copying deployment script via SCP...
                                scp -o StrictHostKeyChecking=no -i "%SSH_KEY%" scripts/deploy.sh %SSH_USER%@${EC2_PUBLIC_IP}:/home/%SSH_USER%/deploy.sh
                                
                                echo [INFO] Executing remote deployment script via SSH...
                                ssh -o StrictHostKeyChecking=no -i "%SSH_KEY%" %SSH_USER%@${EC2_PUBLIC_IP} "chmod +x /home/%SSH_USER%/deploy.sh && /home/%SSH_USER%/deploy.sh ${DOCKER_IMAGE}:latest ${APP_NAME} 8080 8080"
                            """
                        }
                    }
                }
            }
        }
    }

    post {
        always {
            echo "🧹 Cleaning up local Docker build artifacts..."
            script {
                try {
                    if (isUnix()) {
                        sh "docker image prune -f || true"
                    } else {
                        bat "docker image prune -f || exit 0"
                    }
                } catch (Exception e) {
                    echo "Notice: Docker cleanup skipped (${e.getMessage()})"
                }
            }
        }
        success {
            echo "✅ PIPELINE SUCCESSFUL! Application deployed to http://${EC2_PUBLIC_IP}:8080/health"
        }
        failure {
            echo "❌ PIPELINE FAILED! Please inspect stage logs above for failure details."
        }
    }
}
